AI Prompt Design
CATEGORY_PROMPT = """
You are a sustainability-focused e-commerce classifier.

Given product details:
Name: {name}
Description: {description}
Materials: {materials}

Return ONLY structured JSON in this format:

{
  "primary_category": "",
  "sub_category": "",
  "seo_tags": [],
  "sustainability_filters": []
}

Rules:
- Choose primary_category only from provided list.
- Generate 5-10 SEO tags.
- Sustainability filters must be from:
["plastic-free", "compostable", "vegan", "recycled", "biodegradable", "organic", "low-carbon"]
- No explanations. JSON only.
"""
AI Service Layer (Clean Separation)
# ai_service.py
import openai
import os

openai.api_key = os.getenv("OPENAI_API_KEY")

def generate_category(data):
    prompt = CATEGORY_PROMPT.format(**data)
    
    response = openai.ChatCompletion.create(
        model="gpt-4o-mini",
        messages=[{"role": "user", "content": prompt}],
        temperature=0.2
    )
    
    return response.choices[0].message["content"]
Business Logic Layer
# business_logic.py
import json

ALLOWED_FILTERS = [
    "plastic-free", "compostable", "vegan",
    "recycled", "biodegradable", "organic", "low-carbon"
]

def validate_and_structure(ai_output):
    try:
        data = json.loads(ai_output)

        # Validate filters
        data["sustainability_filters"] = [
            f for f in data["sustainability_filters"]
            if f in ALLOWED_FILTERS
        ]

        return data

    except Exception:
        raise ValueError("Invalid AI Output Format")
