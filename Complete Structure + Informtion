рџ“Ѓ module1_category/validator.py
import json

ALLOWED_FILTERS = [
    "plastic-free", "compostable",
    "vegan", "recycled",
    "biodegradable", "organic", "low-carbon"
]

def validate_output(ai_output):
    data = json.loads(ai_output)
    data["sustainability_filters"] = [
        f for f in data["sustainability_filters"]
        if f in ALLOWED_FILTERS
    ]
    return data
